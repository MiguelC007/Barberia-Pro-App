@'
# Dependencies
node_modules/

# Build output
dist/
build/
coverage/

# Firebase local/cache/debug
.firebase/
firebase-debug.log
firestore-debug.log
database-debug.log
ui-debug.log

# Local environment and secrets
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local

# Keep this one public if it has fake/example values
!.env.example

# Private credentials / local seeds
CREDENTIALS.local.md
CREDENTIALS.md
scripts/serviceAccountKey.json
scripts/seed.local.json
scripts/*.local.json
firebase-adminsdk*.json
serviceAccountKey.json
*.pem
*.key
*.p12

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# TypeScript incremental cache
*.tsbuildinfo

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.vs/
.idea/

# Temporary/cache files
.cache/
.temp/
tmp/
'@ | Set-Content -Encoding UTF8 .gitignore